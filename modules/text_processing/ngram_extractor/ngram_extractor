# modules/text/ngram_extractor.py

import pandas as pd
import numpy as np
import time


class NGramExtractor:
    """
    N-gram extraction module (text -> ngram string features).

    Strategies:
      - "word" : word n-grams
      - "char" : character n-grams (including inside words)

    Output format (PipeLens-friendly):
      - Adds ONE new column per processed text column:
            <col>__ngrams
        where the value is a single string containing extracted n-grams separated by spaces.
      - This keeps the output as a normal DataFrame (no sparse matrices),
        and lets your downstream Embedding module (TF-IDF/Count/Hash) vectorize it.

    Behavior:
      - Auto-detect text columns (object/string) unless text_cols provided
      - Works with DataFrame or dict {'train','test'}
      - Does not change row count; y and sensitive unchanged
    """

    def __init__(
        self,
        dataset,
        strategy="word",
        text_cols=None,
        ngram_range=(1, 2),        # (min_n, max_n)
        lowercase=True,
        strip_punct=True,
        drop_original_text=False,  # if True, drop original text cols after creating ngram cols
        verbose=False,
        exclude=None,
    ):
        self.dataset = dataset.copy() if isinstance(dataset, dict) else dataset.copy()
        self.strategy = str(strategy).lower().strip()
        self.text_cols = text_cols

        self.ngram_range = tuple(ngram_range)
        self.lowercase = bool(lowercase)
        self.strip_punct = bool(strip_punct)
        self.drop_original_text = bool(drop_original_text)

        self.verbose = bool(verbose)
        self.exclude = exclude if isinstance(exclude, list) else [exclude] if exclude else []

        if self.strategy not in ("word", "char"):
            raise ValueError("Invalid strategy. Choose from {'word','char'}.")

        if len(self.ngram_range) != 2 or self.ngram_range[0] < 1 or self.ngram_range[1] < self.ngram_range[0]:
            raise ValueError("ngram_range must be a tuple (min_n, max_n) with 1 <= min_n <= max_n.")

    def _detect_text_columns(self, df: pd.DataFrame):
        cols = df.select_dtypes(include=["object", "string"]).columns.tolist()
        cols = [c for c in cols if c not in self.exclude]
        return cols

    def _normalize_text(self, s: str) -> str:
        if s is None:
            s = ""
        s = str(s)
        if self.lowercase:
            s = s.lower()
        if self.strip_punct:
            cleaned = []
            for ch in s:
                if ch.isalnum() or ch.isspace():
                    cleaned.append(ch)
                else:
                    cleaned.append(" ")
            s = "".join(cleaned)
        s = " ".join(s.split())
        return s

    def _word_ngrams(self, tokens, n):
        if len(tokens) < n:
            return []
        return ["_".join(tokens[i : i + n]) for i in range(len(tokens) - n + 1)]

    def _char_ngrams(self, text, n):
        if len(text) < n:
            return []
        # keep spaces to capture cross-token context? Here we remove spaces for char-ngrams for stability.
        t = text.replace(" ", "")
        if len(t) < n:
            return []
        return [t[i : i + n] for i in range(len(t) - n + 1)]

    def _extract_ngrams_from_text(self, text: str) -> str:
        text = self._normalize_text(text)

        min_n, max_n = self.ngram_range
        grams = []

        if self.strategy == "word":
            tokens = text.split() if text else []
            for n in range(min_n, max_n + 1):
                grams.extend(self._word_ngrams(tokens, n))
        else:
            for n in range(min_n, max_n + 1):
                grams.extend(self._char_ngrams(text, n))

        return " ".join(grams)

    def _transform_df(self, df: pd.DataFrame):
        df_out = df.copy()

        text_cols = self._detect_text_columns(df_out) if self.text_cols is None else [
            c for c in self.text_cols if c in df_out.columns and c not in self.exclude
        ]

        for col in text_cols:
            src = df_out[col].fillna("").astype(str)
            df_out[f"{col}__ngrams"] = src.apply(self._extract_ngrams_from_text)

        if self.drop_original_text and len(text_cols) > 0:
            df_out = df_out.drop(columns=text_cols, errors="ignore")

        return df_out

    def transform(self, y_train=None, sensitive_attr_train=None):
        start_time = time.time()
        if self.verbose:
            print("----- Starting N-gram Extraction -----")

        if isinstance(self.dataset, dict):
            out = {"train": self._transform_df(self.dataset["train"].copy())}
            if "test" in self.dataset and self.dataset["test"] is not None:
                out["test"] = self._transform_df(self.dataset["test"].copy())

        elif isinstance(self.dataset, pd.DataFrame):
            out = self._transform_df(self.dataset.copy())

        else:
            raise TypeError("dataset must be a DataFrame or dict {'train','test'}")

        if self.verbose:
            print(f"N-gram extraction completed in {time.time() - start_time:.2f}s")

        return out
